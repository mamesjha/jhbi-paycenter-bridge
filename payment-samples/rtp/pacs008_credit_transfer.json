    "key_differences_from_fednow": {
      "message_version": "RTP uses pacs.008.001.07; FedNow uses pacs.008.001.08",
      "settlement_code": "RTP uses 'TCH' clearing code; FedNow uses 'FDN'",
      "max_amount": "RTP limit is $1,000,000 per transaction (as of 2024); FedNow is $500,000",
      "status_codes": "RTP also uses ACTC (AcceptedTechnicalValidation); FedNow typically does not",
      "confirmation": "RTP requires explicit ACCP within 15 seconds; FedNow within 20 seconds",
      "liquidity": "RTP uses prefunded position at TCH; FedNow uses Prefunded Balance at the Fed",
      "message_wrapper": "RTP uses a proprietary message wrapper format in addition to ISO 20022 body"
    },
    "notes": [
      "RTP is 24x7x365 with a 15-second end-to-end processing requirement",
      "UETR is mandatory (UUID v4)",
      "Account identification uses BBAN (basic bank account number) with routing + account",
      "RTP does not support cross-border payments — USD only, US institutions only",
      "The Clearing House assigns a unique TCH Transaction ID in addition to UETR"
    ]
  },


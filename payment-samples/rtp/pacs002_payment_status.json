{
  "_metadata": {
    "network": "RTP (The Clearing House)",
    "message_type": "pacs.002.001.10",
    "description": "FI to FI Payment Status Report — RTP sends this to confirm, pend, or reject a credit transfer",
    "schema_version": "ISO 20022 pacs.002.001.10",
    "rtp_status_lifecycle": [
      "1. Sender submits pacs.008 → TCH sends ACTC (technical validation passed)",
      "2. TCH routes to receiver → Receiver sends ACWP (accepted, pending posting)",
      "3. Receiver posts to account → Receiver sends ACCP (fully accepted and settled)",
      "OR  Receiver rejects → Receiver sends RJCT within 15 seconds"
    ],
    "status_codes": {
      "ACTC": "AcceptedTechnicalValidation — TCH validated the message format/routing",
      "ACWP": "AcceptedWithoutPosting — receiver FI accepted, not yet posted to account",
      "ACCP": "AcceptedCustomerProfile — posted to creditor account, funds available",
      "RJCT": "Rejected — see StsRsnInf for reason code"
    },
    "rtp_vs_fednow_status": "RTP uses ACTC as an intermediate; FedNow goes directly to ACCP. RTP's 15-second window is tighter than FedNow's 20-second window."
  },


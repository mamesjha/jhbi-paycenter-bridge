{
  "_metadata": {
    "network": "FedNow",
    "message_type": "pain.013.001.07",
    "description": "Creditor Payment Activation Request (Request for Payment / RfP) — creditor pushes a payment request to the debtor's bank",
    "schema_version": "ISO 20022 pain.013.001.07",
    "workflow": [
      "1. Creditor (payee) initiates RfP via their bank",
      "2. Creditor bank sends pain.013 to FedNow",
      "3. FedNow routes to debtor (payer) bank",
      "4. Debtor bank presents RfP to customer",
      "5. Customer approves → pacs.008 credit transfer sent",
      "6. OR customer declines → pain.014 response with RJCT"
    ],
    "notes": [
      "ReqdExctnDt is when the creditor wants to receive funds",
      "XpryDt is when the RfP expires if not acted upon",
      "LinkRef connects the resulting pacs.008 back to this pain.013",
      "pain.013 does NOT move money — it only requests that money be moved",
      "FedNow supports RfP as of June 2024 participant opt-in"
    ]
  },


{
  "_metadata": {
    "network": "FedNow",
    "message_type": "pacs.002.001.10",
    "description": "FI to FI Payment Status Report — sent by the receiving bank to acknowledge or reject a credit transfer",
    "schema_version": "ISO 20022 pacs.002.001.10",
    "status_codes": {
      "ACCP": "AcceptedCustomerProfile — payment accepted and posted to creditor account",
      "ACWP": "AcceptedWithoutPosting — accepted by receiving FI, not yet posted (intermediate state)",
      "PDNG": "Pending — FedNow received the message, validations in progress",
      "RJCT": "Rejected — payment rejected; StsRsnInf.Rsn.Cd is mandatory when RJCT",
      "ACTC": "AcceptedTechnicalValidation — technical validation passed (RTP also uses this; FedNow uses ACCP)"
    },
    "reject_reason_codes": {
      "AC01": "Incorrect account number",
      "AC04": "Closed account number",
      "AC06": "Blocked account",
      "AG01": "Transaction forbidden",
      "AG02": "Invalid bank operation code",
      "AM04": "Insufficient funds",
      "AM05": "Duplicate payment",
      "NARR": "Narrative (free-text reason in AddtlInf)"
    },
    "notes": [
      "OrgnlMsgId and OrgnlMsgNmId must match the pacs.008 they are responding to",
      "OrgnlUETR is mandatory — must echo back the UETR from the credit transfer",
      "FedNow sends ACCP immediately upon successful settlement",
      "RJCT is sent synchronously within the FedNow response window (≤10 seconds)"
    ]
  },


{
  "_metadata": {
    "network": "FedNow",
    "message_type": "FedNow Liquidity Management Transfer (LMT)",
    "description": "Transfers funds between a participating bank's Master Account and its FedNow Prefunded Balance to maintain intraday liquidity for FedNow settlement",
    "underlying_mechanism": "Fedwire Funds Service (pacs.009 Credit Transfer)",
    "iso_message_type": "pacs.009.001.08",
    "notes": [
      "FedNow requires a Prefunded Balance — a pre-funded pool held at the Fed",
      "LMTs move money FROM the bank's Fed Master Account INTO the FedNow Balance (top-up)",
      "Or FROM the FedNow Balance back to the Master Account (drawdown)",
      "LMTs are settled via Fedwire Funds, not via FedNow clearing",
      "FedNow Balance must always be ≥ 0; payments are rejected if balance insufficient",
      "LMTs are typically automated by treasury management systems"
    ],
    "lmt_types": {
      "TOP_UP": "Master Account → FedNow Prefunded Balance (increase available liquidity)",
      "DRAWDOWN": "FedNow Prefunded Balance → Master Account (reclaim excess liquidity)"
    }
  },

